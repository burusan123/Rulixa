<ResourceDictionary x:Class="TemplateHeavyResources.Themes.SharedTemplates"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:TemplateHeavyResources.ViewModels"
                    xmlns:local="clr-namespace:TemplateHeavyResources.OtherViewModels">
    <!--<DataTemplate DataType="{x:Type local:IgnoredShellViewModel}" />-->
    <Style x:Key="BodyText" TargetType="TextBlock">
        <Setter Property="Margin" Value="4" />
    </Style>
    <DataTemplate DataType="{x:Type local:ShellViewModel}">
        <TextBlock Text="Shell" Style="{StaticResource BodyText}" />
    </DataTemplate>
</ResourceDictionary>
