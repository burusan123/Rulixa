<UserControl x:Class="AssessMeister.Presentation.Wpf.Views.ShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:AssessMeister.Presentation.Wpf.ViewModels">
  <UserControl.Resources>
    <DataTemplate DataType="{x:Type viewModels:DashboardPageViewModel}">
      <TextBlock Text="Dashboard" />
    </DataTemplate>
  </UserControl.Resources>
  <Grid>
    <Button Command="{Binding OpenSettingsCommand}" Content="Settings" />
  </Grid>
</UserControl>
